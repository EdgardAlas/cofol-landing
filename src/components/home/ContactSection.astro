---
import SectionLabel from '../SectionLabel.astro';
import { Mail, MapPin } from '@lucide/astro';
import ContactForm from './ContactForm.astro';
import { getCurrentLocale } from '../../i18n/utils';
import { home } from '../../i18n/translations/home';

const lang = getCurrentLocale(Astro.currentLocale);
const t = home[lang];
---

<section id="contact">
  <div class="container mx-auto px-4 py-16 sm:px-6 sm:py-24 lg:px-8 lg:py-32">
    <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-14 xl:gap-20">
      <div class="space-y-7 lg:space-y-8">
        <div class="space-y-4 lg:space-y-5">
          <SectionLabel number="04" title={t.contact.label} />

          <h2
            class="font-heading text-3xl leading-tight font-bold tracking-[-1.2px] sm:text-4xl sm:tracking-[-1.5px] lg:text-6xl lg:leading-15"
          >
            {t.contact.title}
          </h2>
        </div>

        <p
          class="text-sm leading-6 text-neutral-700 sm:text-base sm:leading-7 lg:text-[18px] lg:leading-8"
        >
          {t.contact.description}
        </p>

        <div class="space-y-3 pt-2 sm:space-y-4">
          <div
            class="flex items-center gap-4 rounded-2xl border border-neutral-200 bg-neutral-100 px-5 py-4"
          >
            <span
              class="text-primary-700 flex size-9 shrink-0 items-center justify-center rounded-xl bg-white shadow-sm"
            >
              <Mail size={18} stroke-width={1.75} />
            </span>
            <div>
              <p class="font-mono text-[9px] font-bold tracking-[2.5px] text-neutral-500 uppercase">
                {t.contact.email.label}
              </p>
              <p class="text-sm font-semibold text-neutral-900 sm:text-base">hello@cofol.lab</p>
            </div>
          </div>

          <div
            class="flex items-center gap-4 rounded-2xl border border-neutral-200 bg-neutral-100 px-5 py-4"
          >
            <span
              class="text-primary-700 flex size-9 shrink-0 items-center justify-center rounded-xl bg-white shadow-sm"
            >
              <MapPin size={18} stroke-width={1.75} />
            </span>
            <div>
              <p class="font-mono text-[9px] font-bold tracking-[2.5px] text-neutral-500 uppercase">
                {t.contact.location.label}
              </p>
              <p class="text-sm font-semibold text-neutral-900 sm:text-base">
                {t.contact.location.value}
              </p>
            </div>
          </div>
        </div>
      </div>

      <ContactForm />
    </div>
  </div>
</section>
