---
import SectionLabel from '../SectionLabel.astro';
import philosophyImage from '../../assets/philosophy.png';
import { getCurrentLocale } from '../../i18n/utils';
import { home } from '../../i18n/translations/home';

const lang = getCurrentLocale(Astro.currentLocale);
const t = home[lang];
---

<section id="philosophy">
  <div class="container mx-auto px-4 py-16 sm:px-6 sm:py-24 lg:px-8 lg:py-32">
    <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-14 xl:gap-20">
      <div class="space-y-7 lg:space-y-8">
        <div class="space-y-4 lg:space-y-5">
          <SectionLabel number="03" title={t.philosophy.label} />

          <h2
            class="font-heading text-3xl leading-tight font-bold tracking-[-1.2px] sm:text-4xl sm:tracking-[-1.5px] lg:text-6xl lg:leading-15"
          >
            {t.philosophy.title}
          </h2>
        </div>

        <p
          class="text-sm leading-6 text-neutral-700 sm:text-base sm:leading-7 lg:text-[18px] lg:leading-8"
        >
          {t.philosophy.p1}
        </p>

        <p
          class="text-sm leading-6 text-neutral-700 sm:text-base sm:leading-7 lg:text-[18px] lg:leading-8"
        >
          {t.philosophy.p2}
        </p>

        <ul
          class="space-y-2.5 pt-2 text-sm leading-6 font-semibold text-neutral-950 sm:space-y-3 sm:pt-3 sm:text-base sm:leading-7 lg:text-[18px] lg:leading-8"
        >
          <li class="flex items-center gap-2.5 sm:gap-3">
            <span class="bg-primary-600 size-2 shrink-0 rounded-full sm:size-2.5"></span>
            {t.philosophy.bullet1}
          </li>
          <li class="flex items-center gap-2.5 sm:gap-3">
            <span class="bg-primary-600 size-2 shrink-0 rounded-full sm:size-2.5"></span>
            {t.philosophy.bullet2}
          </li>
          <li class="flex items-center gap-2.5 sm:gap-3">
            <span class="bg-primary-600 size-2 shrink-0 rounded-full sm:size-2.5"></span>
            {t.philosophy.bullet3}
          </li>
        </ul>
      </div>

      <div class="relative mx-auto w-full pb-16 sm:pb-22 lg:order-first lg:mx-0 lg:pb-0">
        <img
          src={philosophyImage.src}
          width={philosophyImage.width}
          height={philosophyImage.height}
          class="aspect-square w-full max-w-130 rounded-4xl object-cover"
          alt={t.philosophy.image.alt}
          loading="lazy"
        />

        <blockquote
          class="text-primary-700 absolute right-3 bottom-8 w-[82%] rounded-2xl bg-neutral-100 p-4 text-sm leading-6 font-semibold shadow-[0_22px_40px_-28px_rgba(28,28,25,0.55)] sm:right-6 sm:w-[64%] sm:rounded-3xl sm:p-6 sm:text-base sm:leading-7 lg:-right-7 lg:-bottom-9 lg:w-[68%] lg:p-7 lg:text-[18px] lg:leading-8"
        >
          {t.philosophy.quote}
        </blockquote>
      </div>
    </div>
  </div>
</section>
