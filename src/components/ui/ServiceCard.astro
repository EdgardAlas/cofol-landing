---
import { cn } from '../../lib/cn';

type Variant = 'large' | 'featured' | 'small' | 'compact';
type IconComponent = (props: {
  class?: string;
  focusable?: string | number | null;
  'aria-hidden'?: boolean;
  'aria-label'?: string;
  'stroke-width'?: string | number;
}) => unknown;

interface Props {
  variant?: Variant;
  title: string;
  description?: string;
  icon?: IconComponent;
  class?: string;
}

const { variant = 'small', title, description, icon: Icon, class: className } = Astro.props;

const wrapperVariants: Record<Variant, string> = {
  large: 'flex flex-col gap-4 rounded-2xl bg-neutral-50 p-6 sm:gap-6 sm:p-8',
  featured: 'flex flex-col gap-4 rounded-2xl bg-primary-800 p-6 sm:gap-6 sm:p-8',
  small: 'flex flex-col gap-4 rounded-2xl bg-neutral-200 p-6 sm:gap-6 sm:p-8',
  compact: 'flex items-center gap-3 rounded-2xl bg-neutral-50 px-5 py-4 sm:gap-4 sm:px-6 sm:py-5',
};

const iconVariants: Record<Variant, string> = {
  large:
    'size-8 rounded-lg bg-neutral-200 text-neutral-700 ring-1 ring-neutral-300 shadow-xs sm:size-10',
  featured:
    'size-8 rounded-lg bg-primary-700/90 text-primary-100 ring-1 ring-primary-600/60 shadow-xs sm:size-10',
  small:
    'size-8 rounded-lg bg-neutral-300 text-neutral-800 ring-1 ring-neutral-400/60 shadow-xs sm:size-10',
  compact:
    'size-10 rounded-lg bg-tertiary-100 text-tertiary-700 ring-1 ring-tertiary-200 shadow-xs sm:size-11',
};

const iconSizeVariants: Record<Variant, string> = {
  large: 'size-6 sm:size-7',
  featured: 'size-6 sm:size-7',
  small: 'size-6 sm:size-7',
  compact: 'size-7 sm:size-8',
};

const titleVariants: Record<Variant, string> = {
  large: 'text-xl text-neutral-950 sm:text-2xl',
  featured: 'text-xl text-primary-50 sm:text-2xl',
  small: 'text-lg text-neutral-950 sm:text-xl',
  compact: 'text-base text-neutral-950 sm:text-lg',
};

const descriptionVariants: Record<Variant, string> = {
  large: 'text-neutral-600',
  featured: 'text-primary-200',
  small: 'text-neutral-600',
  compact: 'text-neutral-600',
};
---

<div class={cn(wrapperVariants[variant], className)}>
  {
    Icon && (
      <div class={cn('flex items-center justify-center', iconVariants[variant])}>
        <Icon aria-hidden={true} class={cn('object-contain', iconSizeVariants[variant])} />
      </div>
    )
  }
  {
    variant === 'compact' ? (
      <h3 class={cn('font-heading font-bold', titleVariants[variant])}>{title}</h3>
    ) : (
      <div class="flex flex-col gap-2">
        <h3 class={cn('font-heading font-bold', titleVariants[variant])}>{title}</h3>
        {description && (
          <p class={cn('text-sm leading-6', descriptionVariants[variant])}>{description}</p>
        )}
      </div>
    )
  }
</div>
