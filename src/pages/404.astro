---
import Layout from '../layouts/Layout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Button from '../components/ui/Button.astro';
import heroBackground from '../assets/home-hero-bg.png';

export const prerender = true;
---

<Layout
  title="404 — Página no encontrada"
  description="Parece que el rincón digital que buscas aún no ha sido cultivado en el ecosistema de COFOL."
  noindex
>
  <div
    style={`background-image: url(${heroBackground.src})`}
    class="bg-contain bg-top-right bg-no-repeat"
  >
    <div class="flex min-h-[70vh] items-center justify-center px-4 py-20 text-center">
      <div class="max-w-xl">
        <div class="mb-8 flex justify-center">
          <SectionLabel number="404" title="Error" />
        </div>
        <h1
          class="font-heading mb-6 text-4xl font-semibold tracking-tight text-neutral-900 sm:text-6xl lg:text-7xl"
        >
          Extraviado en <br /> el <span class="text-primary-700 font-mono font-light italic"
            >biótopo</span
          >
        </h1>
        <p class="mb-10 text-lg leading-relaxed text-neutral-600 sm:text-xl">
          Parece que el rincón digital que buscas aún no ha sido cultivado. Permítenos guiarte de
          vuelta al origen del ecosistema.
        </p>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <Button href="/" variant="primary"> Ir al Inicio </Button>
        </div>
      </div>
    </div>
  </div>
</Layout>
