---
import EcosystemSection from '../components/home/EcosystemSection.astro';
import HomeHero from '../components/home/HomeHero.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <HomeHero />
  <EcosystemSection />
</Layout>

<style is:global>
  #genesis {
    view-timeline: --genesis block;
  }
  #ecosystem {
    view-timeline: --ecosystem block;
  }
  #philosophy {
    view-timeline: --philosophy block;
  }
  #contact {
    view-timeline: --contact block;
  }
</style>
